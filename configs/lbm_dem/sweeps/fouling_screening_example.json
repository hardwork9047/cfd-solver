{
  "schema_version": 1,
  "name": "fouling_screening_example",
  "description": "Small example sweep for fouling sensitivity screening.",
  "defaults": {
    "config": "configs/lbm_dem/templates/fouling_supply.json",
    "geometry": {
      "cylinders": [
        {"x": 75, "y": 25, "radius": 6.0},
        {"x": 75, "y": 45, "radius": 6.0},
        {"x": 105, "y": 25, "radius": 6.0},
        {"x": 105, "y": 45, "radius": 6.0}
      ]
    },
    "runtime": {
      "total_steps": 500,
      "warmup_steps": 100,
      "snapshot_every": 100
    },
    "outputs": {
      "output_profile": "analysis",
      "no_video": true,
      "paraview_output": true
    }
  },
  "factors": {
    "particle_volume_fraction": [0.05, 0.10],
    "rolling_friction": [false, true],
    "particle_fluid_coupling": ["point_force", "immersed_boundary"]
  }
}
